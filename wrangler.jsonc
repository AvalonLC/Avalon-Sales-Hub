{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "avalon-sales-hub",
  "compatibility_date": "2026-05-03",
  "pages_build_output_dir": "./dist",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "avalon-sales-hub-production",
      "database_id": "PLACEHOLDER_REPLACE_WITH_REAL_ID"
    }
  ]
}
